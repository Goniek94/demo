# Backend (apps/api — Etap 1). Skopiuj do apps/api/.env i uzupełnij.
DATABASE_URL="postgresql://user:password@localhost:5432/modamarket?schema=public"

# Operator płatności (Etap 2) — np. Tpay / Przelewy24
PAYMENTS_PROVIDER="TPAY"
PAYMENTS_API_KEY=""
PAYMENTS_API_SECRET=""

# Storage zdjęć (S3-compatible / Supabase)
STORAGE_ENDPOINT=""
STORAGE_BUCKET="modamarket"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

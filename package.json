{
  "name": "modamarket",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "build:web": "npm run build --workspace apps/web",
    "dev:mobile": "npm --prefix apps/mobile start",
    "typecheck": "npm run typecheck --workspace packages/shared && npm run typecheck --workspace apps/web"
  }
}
